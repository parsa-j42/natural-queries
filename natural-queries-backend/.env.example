# Copy this file to .env and fill in values as needed. The real .env is gitignored.

# Environment label, surfaced by /health. Use "production" when deployed.
ENVIRONMENT=development

# Comma-separated list of browser origins allowed to call the API (CORS).
CORS_ORIGINS=https://naturalqueries.parsaj.dev,http://localhost:5173

# LLM provider API keys. Leave a provider blank to rely on bring-your-own-key
# requests from the client for that provider. Anthropic (Claude) is BYO-key only
# in this project, so ANTHROPIC_API_KEY is normally left blank.
GOOGLE_API_KEY=
GROQ_API_KEY=
ANTHROPIC_API_KEY=

# Model used when a request does not specify one. Must be a non-BYO-key model in
# the catalog so it works with the server's keys.
DEFAULT_MODEL=openai/gpt-oss-120b

# Ordered, comma-separated fallback models tried when the chosen one errors.
FALLBACK_MODELS=openai/gpt-oss-120b,llama-3.3-70b-versatile,gemini-3.1-flash-lite

# Cap on output tokens per generation, to bound cost and latency.
MAX_OUTPUT_TOKENS=2048

# Reject questions longer than this many characters.
MAX_QUESTION_CHARS=1000

# Schema sent to the model: "whole" (full schema, safe default) or "keyword"
# (retrieve only the tables a question seems to need: cheaper but lossier).
RETRIEVAL_MODE=whole

# Cache identical requests in memory so repeats are instant and free.
CACHE_ENABLED=true

# Per-IP requests/minute for /generate and /story. 0 disables rate limiting.
RATE_LIMIT_PER_MINUTE=30

# App log verbosity (DEBUG, INFO, WARNING, ERROR).
LOG_LEVEL=INFO
